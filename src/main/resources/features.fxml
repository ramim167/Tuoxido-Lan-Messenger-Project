<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.lanmessenger.FeaturesController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="info-root">
    <content>
        <VBox styleClass="info-shell" spacing="28">
            <padding>
                <Insets top="24" right="28" bottom="28" left="28"/>
            </padding>

            <HBox styleClass="info-topbar" alignment="CENTER_LEFT" spacing="14">
                <StackPane styleClass="brand-logo-wrap">
                    <ImageView fitWidth="40" preserveRatio="true" smooth="true">
                        <image>
                            <Image url="@assets/logo.png"/>
                        </image>
                    </ImageView>
                </StackPane>
                <VBox spacing="1">
                    <Label text="Tuoxido" styleClass="brand-title"/>
                    <Label text="Messaging, refined for clarity" styleClass="brand-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="18" alignment="CENTER_RIGHT">
                    <Hyperlink text="Features" onAction="#onOpenFeatures" styleClass="nav-link nav-link-active" focusTraversable="false"/>
                    <Hyperlink text="Privacy and safety" onAction="#onOpenPrivacySafety" styleClass="nav-link" focusTraversable="false"/>
                    <Hyperlink text="For developers" onAction="#onOpenDevelopers" styleClass="nav-link" focusTraversable="false"/>
                    <Hyperlink text="Help Centre" onAction="#onOpenHelpCenter" styleClass="nav-link" focusTraversable="false"/>
                </HBox>
                <Button text="Back to Login" onAction="#onBackToLogin" styleClass="ghost-btn"/>
            </HBox>

            <HBox styleClass="hero-panel" spacing="28">
                <VBox spacing="14" HBox.hgrow="ALWAYS">
                    <Label text="Feature overview" styleClass="hero-kicker"/>
                    <Label text="Tuoxido keeps chats, calls, and moments in one desktop workspace." wrapText="true" styleClass="hero-title"/>
                    <Label text="Built with JavaFX, Firebase Auth, and MongoDB Atlas, Tuoxido supports one-to-one messaging, group conversations, voice and video calls, and social-style moments without forcing users to switch apps." wrapText="true" styleClass="hero-copy"/>
                </VBox>
                <VBox spacing="16" minWidth="250" maxWidth="250">
                    <VBox styleClass="metric-card" spacing="4">
                        <Label text="Chat, calls, moments" wrapText="true" styleClass="metric-value"/>
                        <Label text="Core communication tools live in one interface, so users can move from text to voice or video without losing context." wrapText="true" styleClass="metric-label"/>
                    </VBox>
                    <VBox styleClass="metric-card" spacing="4">
                        <Label text="Real-time workflow" wrapText="true" styleClass="metric-value"/>
                        <Label text="Inbox refresh, quick message actions, archive controls, and profile shortcuts are tuned for everyday active use." wrapText="true" styleClass="metric-label"/>
                    </VBox>
                </VBox>
            </HBox>

            <VBox spacing="10">
                <Label text="Built for real conversations" styleClass="section-title"/>
                <Label text="Every screen is optimized for speed: open a chat, send, edit, reply, unsend, or archive in a few clicks while staying oriented." wrapText="true" styleClass="section-copy"/>
            </VBox>

            <HBox spacing="18">
                <VBox styleClass="grid-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Inbox experience" styleClass="card-kicker"/>
                    <Label text="Live threads and clean archives" styleClass="card-title"/>
                    <Label text="Recent conversations stay visible, archived chats stay separate, and active threads remain easy to track during busy sessions." wrapText="true" styleClass="card-copy"/>
                    <Region styleClass="card-line"/>
                    <Label text="Search and refresh are designed to reduce hunting for messages, especially in long-running chats." wrapText="true" styleClass="card-copy"/>
                </VBox>
                <VBox styleClass="grid-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Message tools" styleClass="card-kicker"/>
                    <Label text="Reply, edit, and unsend" styleClass="card-title"/>
                    <Label text="Message controls stay inside the same chat flow so corrections and follow-ups happen quickly without opening extra screens." wrapText="true" styleClass="card-copy"/>
                    <Region styleClass="card-line"/>
                    <Label text="That keeps momentum high during both personal and team conversations." wrapText="true" styleClass="card-copy"/>
                </VBox>
                <VBox styleClass="grid-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Identity layer" styleClass="card-kicker"/>
                    <Label text="Profiles and friend system" styleClass="card-title"/>
                    <Label text="Users can update profile details, upload photos, discover people by username, and manage requests from one connected experience." wrapText="true" styleClass="card-copy"/>
                    <Region styleClass="card-line"/>
                    <Label text="Friend management, profile viewing, and chat entry points are coordinated to keep trust and context clear." wrapText="true" styleClass="card-copy"/>
                </VBox>
            </HBox>

            <HBox spacing="18">
                <VBox styleClass="spotlight-panel" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Product direction" styleClass="section-title"/>
                    <Label text="Tuoxido is desktop-first: clear layout, smooth transitions, and practical controls that prioritize communication over visual noise." wrapText="true" styleClass="section-copy"/>
                    <HBox spacing="10">
                        <Label text="Desktop-first" styleClass="mini-chip"/>
                        <Label text="Theme switching" styleClass="mini-chip"/>
                        <Label text="Focused messaging" styleClass="mini-chip"/>
                    </HBox>
                </VBox>
                <VBox styleClass="grid-card" spacing="10" minWidth="280" maxWidth="280">
                    <Label text="Also included" styleClass="card-kicker"/>
                    <Label text="Calls and moments" styleClass="card-title"/>
                    <Label text="Beyond messaging, Tuoxido includes P2P audio and video calling plus a moments feed for lightweight social updates across your network." wrapText="true" styleClass="card-copy"/>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
