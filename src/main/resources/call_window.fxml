<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.lanmessenger.CallController"
           styleClass="call-window-root">

    <VBox spacing="16" alignment="CENTER" maxWidth="860" prefWidth="860" styleClass="call-window-shell">

        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="call-header">
            <VBox spacing="2" alignment="CENTER_LEFT">
                <Label text="LAN Messenger Call" styleClass="call-header-kicker"/>
                <Label fx:id="nameLabel" styleClass="call-name" text="Caller"/>
                <Label fx:id="statusLabel" styleClass="call-status" text="Ringing"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Label fx:id="callTimerLabel" text="00:00" visible="false" managed="false" styleClass="call-timer-chip"/>
                <Label text="Encrypted P2P" styleClass="call-security-chip"/>
            </HBox>
        </HBox>

        <StackPane prefHeight="500" prefWidth="820" styleClass="call-stage">
            <ImageView fx:id="remoteVideo" fitWidth="820" fitHeight="500" preserveRatio="true" smooth="true" visible="false" managed="false"/>

            <VBox fx:id="avatarBox" alignment="CENTER" spacing="14" styleClass="call-avatar-box">
                <StackPane styleClass="call-avatar-ring" prefWidth="126" prefHeight="126" maxWidth="126" maxHeight="126">
                    <ImageView fx:id="avatarImage" fitWidth="118" fitHeight="118" preserveRatio="true" smooth="true"/>
                </StackPane>
                <Label fx:id="callStateHint" text="Ringing" styleClass="call-stage-hint"/>
            </VBox>
        </StackPane>

        <HBox fx:id="incomingActions" alignment="CENTER" spacing="16" styleClass="call-actions">
            <Button onAction="#onAnswer" text="Accept Call" styleClass="call-btn-answer">
                <graphic>
                    <FontIcon iconLiteral="mdi2p-phone" styleClass="call-btn-icon"/>
                </graphic>
            </Button>
            <Button onAction="#onReject" text="Decline" styleClass="call-btn-decline">
                <graphic>
                    <FontIcon iconLiteral="mdi2p-phone-hangup" styleClass="call-btn-icon"/>
                </graphic>
            </Button>
        </HBox>

        <HBox fx:id="inCallActions" alignment="CENTER" spacing="18" visible="false" managed="false" styleClass="call-actions">
            <ToggleButton fx:id="micBtn" onAction="#onToggleMic" styleClass="call-control-toggle">
                <graphic>
                    <FontIcon iconLiteral="mdi2m-microphone" styleClass="call-control-icon"/>
                </graphic>
            </ToggleButton>

            <ToggleButton fx:id="camBtn" onAction="#onToggleCam" styleClass="call-control-toggle">
                <graphic>
                    <FontIcon iconLiteral="mdi2v-video" styleClass="call-control-icon"/>
                </graphic>
            </ToggleButton>

            <Button fx:id="endBtn" onAction="#onEndCall" styleClass="call-control-end">
                <graphic>
                    <FontIcon iconLiteral="mdi2p-phone-hangup" styleClass="call-end-icon"/>
                </graphic>
            </Button>
        </HBox>
    </VBox>
</StackPane>
