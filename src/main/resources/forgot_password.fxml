<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<ScrollPane
        fx:id="root"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.lanmessenger.ForgotPasswordController"
        fitToWidth="true"
        fitToHeight="true"
        hbarPolicy="NEVER"
        vbarPolicy="AS_NEEDED"
        pannable="true"
        onMousePressed="#onBackgroundClick"
        styleClass="login-root">

    <BorderPane fx:id="contentRoot">

        <top>
            <HBox styleClass="topbar" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="18" right="32" bottom="10" left="32"/>
                </padding>

                <ImageView fx:id="logoImage" fitHeight="80" preserveRatio="true"/>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="18" alignment="CENTER_RIGHT">
                    <Hyperlink text="Features"
                               onAction="#onOpenFeatures"
                               styleClass="toplink"
                               focusTraversable="false"/>
                    <Hyperlink text="Privacy and safety"
                               onAction="#onOpenPrivacySafety"
                               styleClass="toplink"
                               focusTraversable="false"/>
                    <Hyperlink text="For developers"
                               onAction="#onOpenDevelopers"
                               styleClass="toplink"
                               focusTraversable="false"/>
                    <Hyperlink text="Help Centre"
                               onAction="#onOpenHelpCenter"
                               styleClass="toplink"
                               focusTraversable="false"/>
                </HBox>
            </HBox>
        </top>

        <center>
            <HBox styleClass="content" alignment="CENTER" spacing="40">
                <padding>
                    <Insets top="10" right="32" bottom="32" left="32"/>
                </padding>

                <VBox styleClass="left" spacing="14" alignment="TOP_LEFT" maxWidth="470">

                    <VBox fx:id="stepEmail" spacing="14" alignment="TOP_LEFT">
                        <Text text="Find&#10;your account" styleClass="headline" lineSpacing="-8"/>
                        <Label wrapText="true"
                               text="Enter your email address and we'll send a 6-digit code."
                               styleClass="subtext"/>

                        <VBox spacing="10" styleClass="form">
                            <TextField fx:id="emailField" promptText="Email address"/>

                            <VBox spacing="8" alignment="CENTER_LEFT" styleClass="actions">
                                <Button fx:id="sendCodeBtn"
                                        text="Send code"
                                        onAction="#onSendCode"
                                        styleClass="primary-btn"/>

                                <HBox alignment="CENTER_LEFT" spacing="2" styleClass="signup-row">
                                    <Label text="Changed your mind?" styleClass="muted"/>
                                    <Hyperlink text="Back to Login" onAction="#onBackToLogin" styleClass="link"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <Label fx:id="statusEmail"
                               text=""
                               wrapText="true"
                               styleClass="status"
                               visible="false"
                               managed="false"/>
                    </VBox>

                    <VBox fx:id="stepCode" spacing="14" alignment="TOP_LEFT" visible="false" managed="false">
                        <Text text="Enter&#10;the code" styleClass="headline" lineSpacing="-8"/>
                        <Label wrapText="true"
                               text="We've sent a 6-digit code to your email. Enter it to continue."
                               styleClass="subtext"/>

                        <VBox spacing="10" styleClass="form">
                            <TextField fx:id="codeField" promptText="6-digit code"/>

                            <VBox spacing="8" alignment="CENTER_LEFT" styleClass="actions">
                                <Button fx:id="verifyCodeBtn"
                                        text="Verify"
                                        onAction="#onVerifyCode"
                                        styleClass="primary-btn"/>

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Hyperlink text="Resend code" onAction="#onResendCode" styleClass="link"/>
                                    <Hyperlink text="Change email" onAction="#onBackToEmail" styleClass="link"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <Label fx:id="statusCode"
                               text=""
                               styleClass="status"
                               visible="false"
                               managed="false"/>
                    </VBox>

                    <VBox fx:id="stepReset" spacing="14" alignment="TOP_LEFT" visible="false" managed="false">
                        <Text text="Set&#10;new password" styleClass="headline" lineSpacing="-8"/>
                        <Label wrapText="true"
                               text="Create a new password to secure your account."
                               styleClass="subtext"/>

                        <VBox spacing="10" styleClass="form">
                            <PasswordField fx:id="newPasswordField" promptText="New password (min 6 chars)"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password"/>

                            <VBox spacing="8" alignment="CENTER_LEFT" styleClass="actions">
                                <Button fx:id="resetBtn"
                                        text="Reset Password"
                                        onAction="#onResetPassword"
                                        styleClass="primary-btn"/>

                                <HBox alignment="CENTER_LEFT" spacing="2" styleClass="signup-row">
                                    <Label text="Need the code again?" styleClass="muted"/>
                                    <Hyperlink text="Back" onAction="#onBackToCode" styleClass="link"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <Label fx:id="statusReset"
                               text=""
                               styleClass="status"
                               visible="false"
                               managed="false"/>
                    </VBox>

                </VBox>

                <StackPane styleClass="right" maxWidth="560" prefWidth="560">
                    <ImageView fx:id="sadImage" styleClass="visual-illustration" preserveRatio="true" smooth="true" cache="true" fitWidth="320"/>
                </StackPane>

            </HBox>
        </center>

    </BorderPane>
</ScrollPane>
