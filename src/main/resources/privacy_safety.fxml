<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.lanmessenger.PrivacySafetyController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="privacy-root">
    <content>
        <VBox styleClass="privacy-shell" spacing="28">
            <padding>
                <Insets top="24" right="28" bottom="28" left="28"/>
            </padding>

            <HBox styleClass="info-topbar" alignment="CENTER_LEFT" spacing="14">
                <StackPane styleClass="brand-logo-wrap">
                    <ImageView fitWidth="40" preserveRatio="true" smooth="true">
                        <image>
                            <Image url="@assets/logo.png"/>
                        </image>
                    </ImageView>
                </StackPane>
                <VBox spacing="1">
                    <Label text="Tuoxido" styleClass="brand-title"/>
                    <Label text="Messaging, refined for clarity" styleClass="brand-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="18" alignment="CENTER_RIGHT">
                    <Hyperlink text="Features" onAction="#onOpenFeatures" styleClass="nav-link" focusTraversable="false"/>
                    <Hyperlink text="Privacy and safety" onAction="#onOpenPrivacySafety" styleClass="nav-link nav-link-active" focusTraversable="false"/>
                    <Hyperlink text="For developers" onAction="#onOpenDevelopers" styleClass="nav-link" focusTraversable="false"/>
                    <Hyperlink text="Help Centre" onAction="#onOpenHelpCenter" styleClass="nav-link" focusTraversable="false"/>
                </HBox>
                <Button text="Back to Login" onAction="#onBackToLogin" styleClass="ghost-btn"/>
            </HBox>

            <HBox styleClass="privacy-hero-panel" spacing="28">
                <VBox spacing="14" HBox.hgrow="ALWAYS">
                    <Label text="Privacy and policy" styleClass="hero-kicker"/>
                    <Label text="Clear safeguards for account access, contacts, and shared content." wrapText="true" styleClass="hero-title"/>
                    <Label text="Tuoxido focuses on practical privacy controls: verified sign-in, recovery tools, and user-managed boundaries for who can stay in your communication space." wrapText="true" styleClass="hero-copy"/>
                </VBox>
                <VBox spacing="16" minWidth="250" maxWidth="250">
                    <VBox styleClass="metric-card" spacing="4">
                        <Label text="Account security" wrapText="true" styleClass="metric-value"/>
                        <Label text="Email verification and password reset are handled through Firebase Authentication to confirm account ownership." wrapText="true" styleClass="metric-label"/>
                    </VBox>
                    <VBox styleClass="metric-card" spacing="4">
                        <Label text="Contact boundaries" wrapText="true" styleClass="metric-value"/>
                        <Label text="Block, remove, and archive options are available in-app so users can control visibility and interaction." wrapText="true" styleClass="metric-label"/>
                    </VBox>
                </VBox>
            </HBox>

            <HBox spacing="18">
                <VBox styleClass="grid-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Data handling" styleClass="card-kicker"/>
                    <Label text="What Tuoxido stores" styleClass="card-title"/>
                    <Label text="Messages, profile details, friendships, groups, and moments are stored in project databases so users can continue across sessions on the same account." wrapText="true" styleClass="card-copy"/>
                </VBox>
                <VBox styleClass="grid-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Access integrity" styleClass="card-kicker"/>
                    <Label text="Verified sign-in journey" styleClass="card-title"/>
                    <Label text="Sign-up, login, verification, and password recovery are part of the normal flow to reduce account lockout risk and unauthorized access." wrapText="true" styleClass="card-copy"/>
                </VBox>
                <VBox styleClass="grid-card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="User control" styleClass="card-kicker"/>
                    <Label text="Manage who can reach you" styleClass="card-title"/>
                    <Label text="Friend tools and blocking actions make it straightforward to stop unwanted communication without contacting support." wrapText="true" styleClass="card-copy"/>
                </VBox>
            </HBox>

            <HBox spacing="18">
                <VBox styleClass="spotlight-panel" spacing="12" HBox.hgrow="ALWAYS">
                    <Label text="Policy in plain language" styleClass="section-title"/>
                    <Label text="Tuoxido is built for transparency: users should understand what actions they can take, what data supports the app experience, and how to quickly recover control of their account." wrapText="true" styleClass="section-copy"/>
                    <HBox spacing="10">
                        <Label text="Verify account" styleClass="mini-chip"/>
                        <Label text="Control contacts" styleClass="mini-chip"/>
                        <Label text="Recover access" styleClass="mini-chip"/>
                    </HBox>
                </VBox>
                <VBox styleClass="grid-card" spacing="10" minWidth="280" maxWidth="280">
                    <Label text="Safety principle" styleClass="card-kicker"/>
                    <Label text="Simple, visible controls" styleClass="card-title"/>
                    <Label text="Important privacy actions stay in normal navigation instead of being buried in complex menus." wrapText="true" styleClass="card-copy"/>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
